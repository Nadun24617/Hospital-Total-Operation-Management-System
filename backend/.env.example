# Database connection string for Prisma (MySQL)
DATABASE_URL="mysql://root:root_password@localhost:3306/htoms_db"

# JWT secret used for signing access tokens
JWT_SECRET="replace-with-strong-secret"

# Token expiration settings
JWT_EXPIRES_IN="1h"

# Frontend origin for CORS
FRONTEND_ORIGIN="http://localhost:5173"

# Backend server port
PORT=3000

# Google Gemini API (free tier: gemini-2.0-flash, 15 RPM / 1500 RPD)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
